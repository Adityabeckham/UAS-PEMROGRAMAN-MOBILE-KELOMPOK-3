rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Task 4.3 (Max): Bug Fix - Allow participants to access their data via token
    // In this demo project, we allow public read/write for participants
    // so they can verify tokens and save answers without Firebase Auth.
    match /participants/{participantId} {
      allow read, write: if true;
    }

    // Reports are sensitive and only for HR Admin (Authenticated)
    match /reports/{reportId} {
      allow read, write: if request.auth != null;
    }

    // Default rule: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}