rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Peserta (participants)
    match /participants/{participantId} {
      // Izinkan baca untuk verifikasi token
      allow read: if true;

      // HANYA boleh update field tertentu (progress, answers, status)
      // Ini mencegah orang iseng mengubah Nama atau Email kandidat lain
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['progress', 'answers', 'status']);
    }

    // 2. Laporan (reports)
    match /reports/{reportId} {
      // HANYA boleh 'create' (buat baru), TIDAK boleh edit atau hapus yang sudah ada
      // Ini mencegah peserta mengubah nilai yang sudah dikirim
      allow create: if true;

      // Hanya Admin yang login yang bisa melihat/membaca daftar laporan
      allow read: if request.auth != null;

      // Tidak ada yang boleh menghapus atau mengubah laporan (termasuk admin dari app)
      // Untuk keamanan data nilai
      allow update, delete: if false;
    }

    // Default: Tolak semua akses lainnya
    match /{document=**} {
      allow read, write: if false;
    }
  }
}