rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Peserta (participants)
    match /participants/{participantId} {
      // Izinkan baca untuk verifikasi token oleh peserta
      allow read: if true;

      // Izinkan HR (Authenticated) untuk mendaftarkan (create) peserta baru
      allow create: if request.auth != null;

      // Izinkan update progress/jawaban oleh peserta atau update penuh oleh HR
      allow update: if request.auth != null ||
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['progress', 'answers', 'status']);
    }

    // 2. Laporan (reports)
    match /reports/{reportId} {
      // Izinkan siapa saja membuat laporan saat selesai ujian
      allow create: if true;

      // Hanya Admin yang login yang bisa melihat laporan
      allow read: if request.auth != null;

      // Laporan tidak boleh diubah atau dihapus
      allow update, delete: if false;
    }

    // Default: Tolak akses lainnya
    match /{document=**} {
      allow read, write: if false;
    }
  }
}